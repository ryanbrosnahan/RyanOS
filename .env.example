NODE_ENV=development

# AI provider. Keep `none` until you are ready to wire Codex login.
# Supported modes: none, codex-login, openai-responses-api, local-llm.
RYANOS_AI_PROVIDER=none
RYANOS_CODEX_COMMAND=codex
# For Docker + Codex app login, run `pnpm codex:bridge` on the host and set:
# RYANOS_AI_PROVIDER=codex-login
# RYANOS_CODEX_BRIDGE_URL=http://host.docker.internal:4111
RYANOS_CODEX_BRIDGE_URL=
RYANOS_CODEX_BRIDGE_TOKEN=
# Optional. Point this at a dedicated empty/read-only bridge workspace if the
# Codex command should not run from the RyanOS repo.
RYANOS_CODEX_WORKDIR=
RYANOS_CODEX_TIMEOUT_MS=180000
# Optional for launchd or other environments where `node` is not on PATH.
RYANOS_NODE_COMMAND=node

# Web/API
# Host ports intentionally avoid 3000/4000 because nearby projects use them.
WEB_PORT=3100
API_PORT=4100
NEXT_PUBLIC_API_URL=http://localhost:4100
RYANOS_CORS_ORIGINS=http://localhost:3100,http://127.0.0.1:3100
# Worker-to-API URL. Docker Compose sets this to http://api:4000 for the worker.
RYANOS_API_URL=http://localhost:4100

# Postgres host ports are intentionally non-default to avoid colliding with
# other local projects.
DB_HOST_PORT=54334
DB_HOST=postgres
DB_PORT=5432
DB_USER=ryanos
DB_PASSWORD=ryanos
DB_NAME=ryanos

# Used when running Node processes directly on the host against Docker Postgres.
DATABASE_URL=postgres://ryanos:ryanos@localhost:54334/ryanos

# Direct host API binding. Docker Compose overrides this to 0.0.0.0 inside
# the container while still publishing only to 127.0.0.1 on the host.
API_HOST=127.0.0.1

# Optional local safety rail for Telegram webhooks. Leave empty for LAN-only
# development, or set comma-separated Telegram user IDs before exposing a tunnel.
TELEGRAM_ALLOWED_USER_IDS=
TELEGRAM_POLL_TIMEOUT_SECONDS=25
TELEGRAM_POLL_LIMIT=20
TELEGRAM_SEND_TYPING=true
TELEGRAM_TYPING_INTERVAL_MS=4500

# Development fallback only. Preferred setup is encrypted DB storage:
# 1. `pnpm secrets:generate-key`
# 2. Put the token in `secrets/telegram-bot-token`
# 3. `docker compose exec api pnpm telegram:store-token -- --file /app/secrets/telegram-bot-token`
TELEGRAM_BOT_TOKEN=

# Master key for encrypted integration secrets. Back this up separately from the
# database; do not commit `secrets/`.
RYANOS_MASTER_KEY_FILE=./secrets/master-key
