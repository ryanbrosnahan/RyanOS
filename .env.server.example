NODE_ENV=production

# Web/API
WEB_PORT=3100
NEXT_PUBLIC_API_URL=/api
RYANOS_INTERNAL_API_URL=http://api:4000
RYANOS_CORS_ORIGINS=

# Auth
RYANOS_AUTH_MODE=required
# Better Auth is self-hosted inside the RyanOS API container; no Better Auth
# managed service is required. Set this to the HTTPS origin users open in the
# browser, for example a Tailscale Serve URL.
BETTER_AUTH_URL=https://change-me.example.ts.net
BETTER_AUTH_SECRET=change-me
# Comma-separated codes allowed to create accounts. Leave no public deployment
# without at least one invite code while sign-up is enabled.
RYANOS_INVITE_CODES=change-me
RYANOS_AUTH_SECURE_COOKIES=true

# Postgres
DB_USER=ryanos
DB_PASSWORD=change-me
DB_NAME=ryanos

# AI provider. For the Lenovo deployment, run the Codex bridge on the host.
RYANOS_AI_PROVIDER=codex-login
RYANOS_CODEX_COMMAND=codex
# The bootstrap script narrows this to the Docker bridge IP when available.
RYANOS_CODEX_BRIDGE_HOST=0.0.0.0
RYANOS_CODEX_BRIDGE_PORT=4111
RYANOS_CODEX_BRIDGE_URL=http://host.docker.internal:4111
RYANOS_CODEX_BRIDGE_TOKEN=change-me
RYANOS_CODEX_WORKDIR=/home/ryan/.local/share/ryanos/codex-workdir
RYANOS_CODEX_TIMEOUT_MS=180000
RYANOS_MASTER_KEY_FILE=/app/secrets/master-key

# Gmail / gog
GOGCLI_VERSION=v0.15.0
GOG_HOME=/app/.gogcli
XDG_CONFIG_HOME=/app/.gogcli
GOG_KEYRING_BACKEND=file
GOG_KEYRING_PASSWORD=change-me
EMAIL_TRIAGE_ENABLED=true
EMAIL_SCAN_QUERY=in:inbox is:unread newer_than:7d
EMAIL_SCAN_MAX_PER_ACCOUNT=25
EMAIL_SCAN_INTERVAL_MINUTES=60

# RFP/grant report sidecars. Paths must be visible inside the worker runtime.
RYANOS_RFP_REPORT_SOURCES=
RFP_REPORT_INGEST_ENABLED=true
RFP_REPORT_INGEST_INTERVAL_MINUTES=60

# Telegram
# Set to "telegram" to keep the Telegram polling container running on deploy.
COMPOSE_PROFILES=
TELEGRAM_ALLOWED_USER_IDS=
# Comma-separated `telegramSenderId:email` entries. These entries also act as
# an allowlist for mapped senders.
TELEGRAM_USER_EMAIL_MAP=
TELEGRAM_POLL_TIMEOUT_SECONDS=25
TELEGRAM_POLL_LIMIT=20
TELEGRAM_SEND_TYPING=true
TELEGRAM_TYPING_INTERVAL_MS=4500
TELEGRAM_BOT_TOKEN=
