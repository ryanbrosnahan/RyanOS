NODE_ENV=production

# Web/API
WEB_PORT=3100
NEXT_PUBLIC_API_URL=/api
RYANOS_INTERNAL_API_URL=http://api:4000
RYANOS_CORS_ORIGINS=

# Postgres
DB_USER=ryanos
DB_PASSWORD=change-me
DB_NAME=ryanos

# AI provider. For the Lenovo deployment, run the Codex bridge on the host.
RYANOS_AI_PROVIDER=codex-login
RYANOS_CODEX_COMMAND=codex
# The bootstrap script narrows this to the Docker bridge IP when available.
RYANOS_CODEX_BRIDGE_HOST=0.0.0.0
RYANOS_CODEX_BRIDGE_PORT=4111
RYANOS_CODEX_BRIDGE_URL=http://host.docker.internal:4111
RYANOS_CODEX_BRIDGE_TOKEN=change-me
RYANOS_CODEX_WORKDIR=/home/ryan/.local/share/ryanos/codex-workdir
RYANOS_CODEX_TIMEOUT_MS=180000
RYANOS_MASTER_KEY_FILE=/app/secrets/master-key

# Gmail / gog
GOGCLI_VERSION=v0.15.0
GOG_HOME=/app/.gogcli
GOG_KEYRING_BACKEND=file
GOG_KEYRING_PASSWORD=change-me
EMAIL_TRIAGE_ENABLED=true
EMAIL_SCAN_QUERY=in:inbox is:unread newer_than:7d
EMAIL_SCAN_MAX_PER_ACCOUNT=25
EMAIL_SCAN_INTERVAL_MINUTES=60

# Telegram
TELEGRAM_ALLOWED_USER_IDS=
TELEGRAM_POLL_TIMEOUT_SECONDS=25
TELEGRAM_POLL_LIMIT=20
TELEGRAM_SEND_TYPING=true
TELEGRAM_TYPING_INTERVAL_MS=4500
TELEGRAM_BOT_TOKEN=
