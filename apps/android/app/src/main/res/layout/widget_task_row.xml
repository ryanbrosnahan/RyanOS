<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
  android:id="@+id/widget_row_root"
  android:layout_width="match_parent"
  android:layout_height="wrap_content"
  android:orientation="vertical"
  android:padding="6dp">

  <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:orientation="horizontal">

    <TextView
      android:id="@+id/widget_area_accent"
      android:layout_width="4dp"
      android:layout_height="44dp"
      android:visibility="gone" />

    <ImageView
      android:id="@+id/widget_item_toggle"
      android:layout_width="32dp"
      android:layout_height="32dp"
      android:layout_marginStart="4dp"
      android:layout_marginEnd="8dp"
      android:contentDescription="Toggle task"
      android:padding="2dp"
      android:src="@drawable/ic_widget_check_circle" />

    <TextView
      android:id="@+id/widget_star_marker"
      android:layout_width="18dp"
      android:layout_height="32dp"
      android:gravity="center"
      android:text="★"
      android:textColor="#B45309"
      android:textSize="15sp"
      android:textStyle="bold"
      android:visibility="gone" />

    <LinearLayout
      android:layout_width="0dp"
      android:layout_height="wrap_content"
      android:layout_weight="1"
      android:orientation="vertical">

      <TextView
        android:id="@+id/widget_item_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:ellipsize="end"
        android:maxLines="1"
        android:textColor="@color/widget_preview_text"
        android:textSize="14sp"
        android:textStyle="bold" />

      <LinearLayout
        android:id="@+id/widget_scope_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:visibility="gone">

        <TextView
          android:id="@+id/widget_area_label"
          android:layout_width="wrap_content"
          android:layout_height="22dp"
          android:gravity="center"
          android:maxLines="1"
          android:minWidth="34dp"
          android:paddingStart="4dp"
          android:paddingEnd="4dp"
          android:textColor="#1F2933"
          android:textSize="11sp"
          android:textStyle="bold" />

        <TextView
          android:id="@+id/widget_project_label"
          android:layout_width="wrap_content"
          android:layout_height="22dp"
          android:layout_marginStart="4dp"
          android:gravity="center"
          android:maxLines="1"
          android:minWidth="34dp"
          android:paddingStart="4dp"
          android:paddingEnd="4dp"
          android:textColor="#1F2933"
          android:textSize="11sp"
          android:textStyle="bold"
          android:visibility="gone" />
      </LinearLayout>

      <TextView
        android:id="@+id/widget_item_detail"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:ellipsize="end"
        android:maxLines="1"
        android:textColor="@color/widget_preview_muted"
        android:textSize="12sp"
        android:visibility="gone" />
    </LinearLayout>

    <TextView
      android:id="@+id/widget_details_toggle"
      android:layout_width="32dp"
      android:layout_height="32dp"
      android:layout_marginStart="6dp"
      android:background="@drawable/widget_button_background"
      android:gravity="center"
      android:maxLines="1"
      android:text="⋯"
      android:textColor="@color/widget_preview_muted"
      android:textSize="16sp"
      android:textStyle="bold"
      android:visibility="gone" />

    <TextView
      android:id="@+id/widget_days_toggle"
      android:layout_width="56dp"
      android:layout_height="32dp"
      android:layout_marginStart="6dp"
      android:background="@drawable/widget_button_background"
      android:gravity="center"
      android:maxLines="1"
      android:text="Days"
      android:textColor="@color/widget_preview_muted"
      android:textSize="12sp"
      android:textStyle="bold"
      android:visibility="gone" />
  </LinearLayout>

  <LinearLayout
    android:id="@+id/widget_days_container"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:visibility="gone">

    <LinearLayout
      android:id="@+id/widget_days_row"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="6dp"
      android:orientation="horizontal">

      <TextView
        android:id="@+id/widget_day_0"
        android:layout_width="30dp"
        android:layout_height="28dp"
        android:gravity="center"
        android:textSize="11sp"
        android:textStyle="bold" />

      <TextView
        android:id="@+id/widget_day_1"
        android:layout_width="30dp"
        android:layout_height="28dp"
        android:layout_marginStart="3dp"
        android:gravity="center"
        android:textSize="11sp"
        android:textStyle="bold" />

      <TextView
        android:id="@+id/widget_day_2"
        android:layout_width="30dp"
        android:layout_height="28dp"
        android:layout_marginStart="3dp"
        android:gravity="center"
        android:textSize="11sp"
        android:textStyle="bold" />

      <TextView
        android:id="@+id/widget_day_3"
        android:layout_width="30dp"
        android:layout_height="28dp"
        android:layout_marginStart="3dp"
        android:gravity="center"
        android:textSize="11sp"
        android:textStyle="bold" />

      <TextView
        android:id="@+id/widget_day_4"
        android:layout_width="30dp"
        android:layout_height="28dp"
        android:layout_marginStart="3dp"
        android:gravity="center"
        android:textSize="11sp"
        android:textStyle="bold" />

      <TextView
        android:id="@+id/widget_day_5"
        android:layout_width="30dp"
        android:layout_height="28dp"
        android:layout_marginStart="3dp"
        android:gravity="center"
        android:textSize="11sp"
        android:textStyle="bold" />

      <TextView
        android:id="@+id/widget_day_6"
        android:layout_width="30dp"
        android:layout_height="28dp"
        android:layout_marginStart="3dp"
        android:gravity="center"
        android:textSize="11sp"
        android:textStyle="bold" />
    </LinearLayout>

    <TextView
      android:id="@+id/widget_last_done"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="4dp"
      android:ellipsize="end"
      android:maxLines="1"
      android:textColor="@color/widget_preview_muted"
      android:textSize="11sp"
      android:visibility="gone" />
  </LinearLayout>

  <LinearLayout
    android:id="@+id/widget_details_container"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="6dp"
    android:orientation="vertical"
    android:visibility="gone">

    <TextView
      android:id="@+id/widget_progress_note_0"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:ellipsize="end"
      android:maxLines="1"
      android:textColor="@color/widget_preview_muted"
      android:textSize="11sp"
      android:visibility="gone" />

    <TextView
      android:id="@+id/widget_progress_note_1"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="2dp"
      android:ellipsize="end"
      android:maxLines="1"
      android:textColor="@color/widget_preview_muted"
      android:textSize="11sp"
      android:visibility="gone" />

    <TextView
      android:id="@+id/widget_checklist_summary"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="4dp"
      android:ellipsize="end"
      android:maxLines="1"
      android:textColor="@color/widget_preview_text"
      android:textSize="11sp"
      android:textStyle="bold"
      android:visibility="gone" />

    <TextView
      android:id="@+id/widget_checklist_0"
      android:layout_width="match_parent"
      android:layout_height="24dp"
      android:gravity="center_vertical"
      android:maxLines="1"
      android:textColor="@color/widget_preview_text"
      android:textSize="12sp"
      android:visibility="gone" />

    <TextView
      android:id="@+id/widget_checklist_1"
      android:layout_width="match_parent"
      android:layout_height="24dp"
      android:gravity="center_vertical"
      android:maxLines="1"
      android:textColor="@color/widget_preview_text"
      android:textSize="12sp"
      android:visibility="gone" />

    <TextView
      android:id="@+id/widget_checklist_2"
      android:layout_width="match_parent"
      android:layout_height="24dp"
      android:gravity="center_vertical"
      android:maxLines="1"
      android:textColor="@color/widget_preview_text"
      android:textSize="12sp"
      android:visibility="gone" />

    <TextView
      android:id="@+id/widget_checklist_3"
      android:layout_width="match_parent"
      android:layout_height="24dp"
      android:gravity="center_vertical"
      android:maxLines="1"
      android:textColor="@color/widget_preview_text"
      android:textSize="12sp"
      android:visibility="gone" />

    <TextView
      android:id="@+id/widget_checklist_4"
      android:layout_width="match_parent"
      android:layout_height="24dp"
      android:gravity="center_vertical"
      android:maxLines="1"
      android:textColor="@color/widget_preview_text"
      android:textSize="12sp"
      android:visibility="gone" />

    <TextView
      android:id="@+id/widget_checklist_5"
      android:layout_width="match_parent"
      android:layout_height="24dp"
      android:gravity="center_vertical"
      android:maxLines="1"
      android:textColor="@color/widget_preview_text"
      android:textSize="12sp"
      android:visibility="gone" />
  </LinearLayout>
</LinearLayout>
