<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:background="@color/widget_preview_background"
  android:orientation="vertical"
  android:padding="12dp">

  <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:orientation="horizontal">

    <ImageView
      android:layout_width="24dp"
      android:layout_height="24dp"
      android:contentDescription="@string/app_name"
      android:src="@drawable/ic_launcher" />

    <TextView
      android:layout_width="0dp"
      android:layout_height="wrap_content"
      android:layout_marginStart="8dp"
      android:layout_weight="1"
      android:ellipsize="end"
      android:maxLines="1"
      android:text="Shopping"
      android:textColor="@color/widget_preview_text"
      android:textSize="16sp"
      android:textStyle="bold" />

    <TextView
      android:layout_width="wrap_content"
      android:layout_height="40dp"
      android:gravity="center"
      android:minWidth="72dp"
      android:text="Refresh"
      android:textColor="@color/widget_preview_text"
      android:textSize="13sp" />
  </LinearLayout>

  <TextView
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="16dp"
    android:text="No shopping items"
    android:textColor="@color/widget_preview_muted"
    android:textSize="14sp" />

  <TextView
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="8dp"
    android:text="Add groceries, household goods, personal care, health, and miscellaneous items."
    android:textColor="@color/widget_preview_muted"
    android:textSize="12sp" />
</LinearLayout>
