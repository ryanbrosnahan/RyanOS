<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
  android:id="@+id/vocabulary_widget_root"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:background="@color/widget_preview_background"
  android:orientation="vertical"
  android:padding="12dp">

  <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:orientation="horizontal">

    <ImageView
      android:id="@+id/vocabulary_widget_logo"
      android:layout_width="24dp"
      android:layout_height="24dp"
      android:contentDescription="@string/app_name"
      android:src="@drawable/ic_launcher" />

    <TextView
      android:id="@+id/vocabulary_widget_title"
      android:layout_width="0dp"
      android:layout_height="wrap_content"
      android:layout_marginStart="8dp"
      android:layout_weight="1"
      android:ellipsize="end"
      android:maxLines="1"
      android:text="Vocabulary"
      android:textColor="@color/widget_preview_text"
      android:textSize="16sp"
      android:textStyle="bold" />

    <TextView
      android:id="@+id/vocabulary_widget_refresh"
      android:layout_width="wrap_content"
      android:layout_height="36dp"
      android:background="@drawable/widget_button_background"
      android:gravity="center"
      android:minWidth="78dp"
      android:text="Refresh"
      android:textColor="@color/widget_preview_text"
      android:textSize="13sp"
      android:textStyle="bold" />

    <TextView
      android:id="@+id/vocabulary_widget_add"
      android:layout_width="wrap_content"
      android:layout_height="36dp"
      android:layout_marginStart="6dp"
      android:background="@drawable/widget_button_background"
      android:gravity="center"
      android:minWidth="52dp"
      android:text="Add"
      android:textColor="@color/widget_preview_text"
      android:textSize="13sp"
      android:textStyle="bold" />
  </LinearLayout>

  <TextView
    android:id="@+id/vocabulary_widget_empty"
    android:layout_width="match_parent"
    android:layout_height="0dp"
    android:layout_marginTop="10dp"
    android:layout_weight="1"
    android:gravity="top"
    android:text="No vocabulary entries"
    android:textColor="@color/widget_preview_muted"
    android:textSize="14sp"
    android:visibility="gone" />

  <ListView
    android:id="@+id/vocabulary_widget_list"
    android:layout_width="match_parent"
    android:layout_height="0dp"
    android:layout_marginTop="8dp"
    android:layout_weight="1"
    android:cacheColorHint="@android:color/transparent"
    android:divider="@android:color/transparent"
    android:dividerHeight="6dp"
    android:fadingEdge="none"
    android:footerDividersEnabled="false"
    android:headerDividersEnabled="false"
    android:overScrollMode="ifContentScrolls"
    android:scrollbarStyle="insideOverlay"
    android:scrollbars="vertical" />
</LinearLayout>
