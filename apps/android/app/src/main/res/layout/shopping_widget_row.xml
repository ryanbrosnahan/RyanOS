<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
  android:id="@+id/shopping_row_root"
  android:layout_width="match_parent"
  android:layout_height="wrap_content"
  android:gravity="center_vertical"
  android:orientation="horizontal"
  android:padding="6dp">

  <ImageView
    android:id="@+id/shopping_item_toggle"
    android:layout_width="32dp"
    android:layout_height="32dp"
    android:layout_marginEnd="8dp"
    android:contentDescription="Toggle shopping item"
    android:padding="2dp"
    android:src="@drawable/ic_widget_check_circle" />

  <LinearLayout
    android:layout_width="0dp"
    android:layout_height="wrap_content"
    android:layout_weight="1"
    android:orientation="vertical">

    <TextView
      android:id="@+id/shopping_item_title"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:ellipsize="end"
      android:maxLines="1"
      android:textColor="@color/widget_preview_text"
      android:textSize="14sp"
      android:textStyle="bold" />

    <TextView
      android:id="@+id/shopping_item_detail"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:ellipsize="end"
      android:maxLines="1"
      android:textColor="@color/widget_preview_muted"
      android:textSize="12sp"
      android:visibility="gone" />
  </LinearLayout>

  <TextView
    android:id="@+id/shopping_category_label"
    android:layout_width="wrap_content"
    android:layout_height="26dp"
    android:layout_marginStart="6dp"
    android:ellipsize="end"
    android:gravity="center"
    android:maxLines="1"
    android:maxWidth="108dp"
    android:minWidth="54dp"
    android:paddingStart="6dp"
    android:paddingEnd="6dp"
    android:textColor="#1F2933"
    android:textSize="11sp"
    android:textStyle="bold" />
</LinearLayout>
